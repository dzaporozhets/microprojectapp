<div class="">
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h1 class="resource-title">Settings</h1>
        <p class="resource-description">Manage your account preferences, privacy settings, and appearance.</p>
      </div>
    </div>

    <%= form_for(@user, url: users_settings_path, html: { method: :put }, data: { turbo: false }) do |f| %>
      <%= render "shared/errors", resource: @user %>

      <div class="form-section">
        <div class="form-group">
          <div class="form-group-header">
            <h2 class="resource-subtitle">Privacy and Security</h2>
          </div>

          <div class="space-y-4">
            <div class="flex items-center">
              <%= f.check_box :allow_invites, class: 'checkbox' %>
              <%= f.label :allow_invites, "Allow other users to add you to projects", class: 'ml-2 text-sm text-default' %>
            </div>
          </div>
        </div>

        <div class="form-group">
          <div class="form-group-header">
            <h2 class="resource-subtitle">Appearance</h2>
            <p class="form-hint">Choose your preferred dark mode setting</p>
          </div>

          <div class="space-y-4 mb-6">
            <div class="flex items-center">
              <%= f.radio_button :dark_mode, :on, class: "h-4 w-4 radio" %>
              <%= f.label :dark_mode_on, "Light", class: "ml-2 block text-sm font-medium text-gray-900 dark:text-gray-200" %>
            </div>

            <div class="flex items-center">
              <%= f.radio_button :dark_mode, :off, class: "h-4 w-4 radio" %>
              <%= f.label :dark_mode_off, "Dark", class: "ml-2 block text-sm font-medium text-gray-900 dark:text-gray-200" %>
            </div>

            <div class="flex items-center">
              <%= f.radio_button :dark_mode, :auto, class: "h-4 w-4 radio" %>
              <%= f.label :dark_mode_auto, "Auto", class: "ml-2 block text-sm font-medium text-gray-900 dark:text-gray-200" %>
            </div>
          </div>

          <div>
            <%= f.label :theme, "Theme", class: "form-label" %>
            <%= f.select :theme,
              User.available_themes.map { |id, name| [name, id] }, {},
              class: "block w-full base-input" %>
          </div>

          <div class="mt-4">
            <div class="flex items-center">
              <%= f.check_box :compact_mode, class: 'checkbox' %>
              <%= f.label :compact_mode, "Compact mode", class: 'ml-2 text-sm text-default' %>
            </div>
            <p class="form-hint text-xs mt-1">Slightly reduces the UI scale for a more compact layout</p>
          </div>
        </div>

        <% if file_storage_enabled? %>
          <div class="form-group">
            <div class="form-group-header">
              <h2 class="resource-subtitle">Avatar</h2>
            </div>

            <div class="flex items-center justify-between space-x-4">
              <div class="flex-grow">
                <%= f.file_field :avatar,
                  accept: allowed_img_file_types,
                  class: "appearance-none file-select text-sm leading-tight file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium w-full" %>
              </div>

              <div class="flex-shrink-0">
                <% if avatar_src(@user).present? %>
                  <%= image_tag avatar_src(@user), alt: "Current Avatar", class: "w-10 h-10 rounded-full object-cover" %>
                <% end %>
              </div>
            </div>
          </div>
        <% elsif @user.oauth_avatar_url.present? %>
          <div class="form-group">
            <div class="form-group-header">
              <h2 class="resource-subtitle">Avatar</h2>
            </div>

            <div class="flex items-center space-x-4">
              <div class="flex-shrink-0">
                <%= image_tag avatar_src(@user), alt: "Current Avatar", class: "w-10 h-10 rounded-full object-cover" %>
              </div>
              <p class="form-hint">Avatar provided by OAuth login</p>
            </div>
          </div>
        <% else %>
          <div class="form-group">
            <div class="form-group-header">
              <h2 class="resource-subtitle">Avatar</h2>
            </div>

            <div class="flex items-center space-x-4">
              <div class="flex items-center">
                <%= f.check_box :use_gravatar, class: 'checkbox' %>
                <%= f.label :use_gravatar, "Use Gravatar", class: 'ml-2 text-sm text-default' %>
              </div>

              <% if avatar_src(@user).present? %>
                <div class="flex-shrink-0">
                  <%= image_tag avatar_src(@user), alt: "Current Avatar", class: "w-10 h-10 rounded-full object-cover" %>
                </div>
              <% end %>
            </div>

            <p class="form-hint text-xs mt-2">Display your <a href="https://gravatar.com" target="_blank" class="underline">Gravatar</a> based on your email address</p>
          </div>
        <% end %>

        <div class="form-group">
          <%= f.submit "Save Settings", class: "btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
