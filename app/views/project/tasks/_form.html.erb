<%- task = defined?(task) && task ? task : Task.new %>
<%= turbo_frame_tag "new_task" do %>
  <%= form_with(model: [project, task], local: false, class: '') do |form| %>
    <%= hidden_field_tag :sctl, params[:sctl] || (current_page?(project_path(project)) ? 'projects' : 'tasks') %>

    <% if task.errors.any? %>
      <div id="ar-errors-text" data-turbo-cache="false" class="p-4 mb-4 bg-gray-50 rounded-md border text-red-700">
        <%= render("project/tasks/form_errors", resource: task) %>
      </div>
    <% end %>

    <div class="mb-4 flex items-center w-full bg-base px-4 py-2 border border-base rounded-md focus-within:border-gray-400 dark:focus-within:border-gray-600">
      <%= link_to new_project_task_path(project), class: "hidden sm:flex items-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 shrink-0 mr-1", data: { turbo: false }, title: "Advanced options" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
      <% end %>

      <div class="flex-grow">
        <%= form.text_field :name, class: "w-full text-sm p-2 border-none bg-transparent text-black dark:text-white font-base placeholder-gray-700 dark:placeholder-gray-300 focus:border-none focus:ring-0 outline-none focus:outline-none shadow-none", required: true, placeholder: "What needs to be done?", autocomplete: "off", inputmode: 'text' %>
      </div>

      <div class="hidden sm:flex items-center gap-2 text-xs text-muted shrink-0 ml-2">
        <kbd class="px-1.5 py-0.5 rounded border border-base bg-gray-50 dark:bg-gray-800 text-[10px] font-medium">↵</kbd>
        <span>to add</span>
      </div>

      <%= form.button type: :submit, title: 'Add task', class: "sm:hidden flex items-center justify-center btn-base ml-2 p-1.5 rounded-md" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      <% end %>
    </div>
  <% end %>
<% end %>


<button
    id="floating-plus"
    title="Add Task"
    class="fixed bottom-6 right-6 z-50 block md:hidden p-4 btn-base rounded-full shadow-lg focus:outline-none"
    data-controller="set-value" data-action="click->set-value#focus" data-target-id="task_name"
    >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
</button>
