<div>
  <div class="text-secondary space-y-1">
    <% if task.assigned_user_id %>
      <div class="flex items-baseline">
        <span class="w-24 shrink-0">Assigned:</span>
        <span class="min-w-0 break-words"><%= task.assigned_user&.email %></span>
      </div>
    <% end %>

    <% if task.due_date.present? %>
      <div class="flex items-baseline">
        <span class="w-24 shrink-0">Due:</span>
        <span class="min-w-0 break-words flex items-center gap-2">
          <%= l(task.due_date.to_date, format: :long) %>
          <% if !task.done? && task.due_date < Date.current %>
            <span class="status-dot-overdue" title="Overdue task" aria-label="Overdue task"></span>
          <% end %>
        </span>
      </div>
    <% end %>

    <div class="flex items-baseline">
      <span class="w-24 shrink-0">Created:</span>
      <span class="min-w-0 break-words"><%= "#{l(task.created_at, format: :long)} by #{task.user.email}" %></span>
    </div>

    <div class="flex items-baseline">
      <span class="w-24 shrink-0">Updated:</span>
      <span class="min-w-0 break-words">
        <% if task.updated_by_user.present? %>
          <%= "#{l(task.updated_at, format: :long)} by #{task.updated_by_user.email}" %>
        <% elsif task.updated_by_user_id.present? %>
          <%= "#{l(task.updated_at, format: :long)} by (deleted)" %>
        <% else %>
          <%= l(task.updated_at, format: :long) %>
        <% end %>
      </span>
    </div>

    <% if task.done && task.done_at %>
      <div class="flex items-baseline">
        <span class="w-24 shrink-0">Completed at:</span>
        <span class="min-w-0 break-words"><%= l(task.done_at, format: :long) %></span>
      </div>
    <% end %>
  </div>
</div>
