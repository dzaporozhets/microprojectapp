<div class="resource-container">
  <div class="resource-header">
    <div class="flex items-center justify-between w-full">
      <div class="flex items-center">
        <%= form_with(model: @task, url: project_task_path(@task.project, @task), local: false, data: { turbo: false }) do |form| %>
          <%= form.label :done, class: 'flex items-center' do %>
            <%= form.check_box :done,
              checked: @task.done,
              id: "task_#{@task.id}",
              class: "w-5 h-5 checkbox-round mr-2",
              data: { turbo_action: "advance", controller: "auto-submit", action: "change->auto-submit#submit" } %>
            <span class="text-sm text-gray-600 dark:text-gray-400">
              <%= @task.done ? 'Completed' : 'Mark as completed' %>
            </span>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center space-x-2">
        <%= link_to toggle_star_project_task_path(@task.project, @task), method: :patch, data: { turbo: true, turbo_method: :patch }, class: 'btn-sm', title: 'Star' do %>
          <%= render 'project/tasks/star', task: @task, text: true %>
        <% end %>

        <%= link_to edit_project_task_path(@task.project, @task), data: { turbo: true }, class: 'btn-sm', title: 'Edit' do %>
          <%= edit_icon %>
        <% end %>

        <%= link_to collapse_task_path(@task.project), class: 'btn-sm', data: { turbo: true }, title: 'Back to tasks list' do %>
          <%= close_icon %>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <div class="m-4 space-y-4">
      <div class="task-details">
        <h1 class="task-title">
          <%= @task.name %>
        </h1>

        <% if @task.description.present? %>
          <div class="mt-1 user-content"><%= format_user_content(@task.description) %></div>
        <% end %>

      </div>

      <%= render 'project/tasks/metadata', task: @task %>

      <div class="flex items-center gap-2 flex-wrap">
        <% if @task.assigned_user_id %>
          <%= button_to "Unassign",
              project_task_path(@task.project, @task, task: { assigned_user_id: "" }),
              method: :patch, data: { turbo: false }, class: "btn-base-sm" %>
        <% else %>
          <%= button_to "Assign to myself",
              project_task_path(@task.project, @task, task: { assigned_user_id: current_user.id }),
              method: :patch, data: { turbo: false }, class: "btn-base-sm" %>
        <% end %>
        <%= button_to "Today",
            project_task_path(@task.project, @task, task: { due_date: Date.current }),
            method: :patch, data: { turbo: false }, class: "btn-base-sm" %>
        <%= button_to "Tomorrow",
            project_task_path(@task.project, @task, task: { due_date: Date.tomorrow }),
            method: :patch, data: { turbo: false }, class: "btn-base-sm" %>
        <%= button_to "Monday",
            project_task_path(@task.project, @task, task: { due_date: Date.current.next_occurring(:monday) }),
            method: :patch, data: { turbo: false }, class: "btn-base-sm" %>
      </div>
    </div>

    <div class="task-comments">
      <%= render 'project/tasks/comments' %>
    </div>
  </div>
</div>
