<div class="space-y-6">
  <div class="resource-container">
    <div class="resource-header">
      <div class="flex items-center justify-between w-full">
        <div>
          <h1 class="resource-title">Change history</h1>
          <p class="resource-description">Last 4 changes</p>
        </div>

        <div class="flex items-center space-x-2">
          <%= link_to edit_project_task_path(@project, @task), class: "btn-sm", title: "Close" do %>
            <%= close_icon %>
          <% end %>
        </div>
      </div>
    </div>

    <% if @versions.any? %>
      <div class="p-4 space-y-4">
        <% @versions.reverse_each do |version| %>
          <% next if version.changeset.blank? %>
          <% old_name = version.changeset.dig("name", 0) %>
          <% old_description = version.changeset.dig("description", 0) %>

          <div class="version-card">
            <div class="version-card-header">
              <p class="version-card-title"><%= @task.name %></p>
              <span class="version-card-meta">
                <%= time_ago_in_words(version.created_at) %> ago by <%= @users_by_version[version.id]&.email || "Unknown" %>
              </span>
            </div>
            <div class="version-card-body">
              <% if old_name.present? %>
                <p class="font-medium text-sm text-gray-900 dark:text-gray-200"><%= old_name %></p>
              <% end %>
              <% if old_description.present? %>
                <div class="user-content"><%= format_user_content(old_description) %></div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-4">
        <p class="text-sm text-muted">No changes yet.</p>
      </div>
    <% end %>
  </div>
</div>
