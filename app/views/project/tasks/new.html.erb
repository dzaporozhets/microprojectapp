<%= display_flash %>

<div class="resource-container">
  <div class="resource-header">
    <div class="flex items-center justify-between w-full">
      <div>
        <h1 class="resource-title">New task</h1>
      </div>

      <div class="flex items-center space-x-2">
        <%= link_to collapse_task_path(@project), class: 'btn-sm', data: { turbo: true }, title: 'Back to tasks list' do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <%= form_with(model: [@project, @task], data: { turbo: false }) do |form| %>
      <% if @task.errors.any? %>
        <div id="ar-errors-text" data-turbo-cache="false" class="error-box">
          <%= render("project/tasks/form_errors", resource: @task) %>
        </div>
      <% end %>

      <div class="form-section">
        <div class="p-4">
          <div>
            <%= form.label :name, class: "form-label" %>
            <%= form.text_area :name, class: "block w-full base-input", required: true, rows: 2, placeholder: "Enter task name..." %>
          </div>
        </div>

        <div class="p-4">
          <div>
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, class: "block w-full base-input resize-y", rows: 3, placeholder: "Enter task description..." %>
          </div>
        </div>

        <div class="p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <%= form.label :due_date, class: "form-label" %>
              <%= form.date_field :due_date, class: "block w-full base-input" %>
            </div>

            <% unless @project.personal? %>
              <div>
                <%= form.label :assigned_user_id, class: "form-label" %>
                <%= form.collection_select :assigned_user_id, @project.team, :id, :email, { include_blank: "None" }, { class: "block w-full base-input" } %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="p-4">
          <%= form.submit 'Create task', class: "btn-base" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
