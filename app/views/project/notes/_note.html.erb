<li id="<%= dom_id note %>">
  <div class="list-row">
    <div class="flex items-center min-w-0">
      <!-- Note icon -->
      <div class="flex-shrink-0 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </div>

      <div class="list-item-content">
        <div class="flex items-center">
          <%= link_to project_note_path(note.project, note), class: "link-primary list-text-primary truncate" do %>
            <%= note.title %>
          <% end %>
        </div>
        <div class="mt-1 flex items-center list-text-secondary">
          <% if note.content.present? %>
            <span><%= note.content.truncate(50) %></span>
            <span class="mx-1">&middot;</span>
          <% end %>
          <% if note.created_at.present? %>
            <span>Added <%= time_ago_in_words(note.created_at) %> ago</span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="list-item-actions">
      <!-- View button -->
      <%= link_to project_note_path(note.project, note), class: "icon-btn", title: "View" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      <% end %>

      <!-- Delete button -->
      <%= button_to project_note_path(note.project, note), method: :delete, data: { "turbo-method": :delete, turbo_confirm: 'Delete this note? Are you sure?' }, alt: 'Delete note', class: "icon-btn", title: "Delete" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      <% end %>
    </div>
  </div>
</li>
