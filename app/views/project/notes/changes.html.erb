<div class="space-y-6">
  <div class="resource-container">
    <div class="resource-header">
      <div class="flex items-center justify-between w-full">
        <div>
          <h1 class="resource-title">Change history</h1>
          <p class="resource-description">Last 4 changes</p>
        </div>

        <div class="flex items-center space-x-2">
          <%= link_to edit_project_note_path(@project, @note), class: "btn-sm", title: "Close" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          <% end %>
        </div>
      </div>
    </div>

    <% if @versions.any? %>
      <div class="p-4 space-y-4">
        <% @versions.reverse.first(4).each do |version| %>
          <% old_content = version.changeset.dig("content", 0) if version.changeset.present? %>
          <% next unless old_content.present? %>
          <div class="version-card">
            <div class="version-card-header">
              <p class="version-card-title"><%= @note.title %></p>
              <span class="version-card-meta">
                <%= time_ago_in_words(version.created_at) %> ago by <%= @users_by_version[version.id]&.email || "Unknown" %>
              </span>
            </div>
            <div class="version-card-body">
              <div class="prose dark:prose-invert max-w-none text-sm break-words">
                <%= format_user_content(old_content) %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-4">
        <p class="text-sm text-muted">No changes yet.</p>
      </div>
    <% end %>
  </div>
</div>
