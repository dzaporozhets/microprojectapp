<div class="space-y-6">
  <div class="resource-container">
    <div class="resource-header">
      <div class="flex items-center justify-between w-full">
        <div>
          <h1 class="resource-title">Change history</h1>
          <p class="resource-description">Last 4 changes</p>
        </div>

        <div class="flex items-center space-x-2">
          <%= link_to edit_project_note_path(@project, @note), class: "btn-sm", title: "Close" do %>
            <%= close_icon %>
          <% end %>
        </div>
      </div>
    </div>

    <% if @versions.any? %>
      <div class="p-4 space-y-4">
        <% @versions.reverse_each do |version| %>
          <% old_content = version.changeset&.dig("content", 0) %>
          <% next if old_content.blank? %>

          <div class="version-card">
            <div class="version-card-header">
              <p class="version-card-title"><%= @note.title %></p>
              <span class="version-card-meta">
                <%= time_ago_in_words(version.created_at) %> ago by <%= @users_by_version[version.id]&.email || "Unknown" %>
              </span>
            </div>
            <div class="version-card-body">
              <div class="user-content"><%= format_user_content(old_content) %></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-4">
        <p class="text-sm text-muted">No changes yet.</p>
      </div>
    <% end %>
  </div>
</div>
