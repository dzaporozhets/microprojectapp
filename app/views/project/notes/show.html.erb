<div class="">
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h1 class="resource-title"><%= @note.title %></h1>
        <p class="resource-description">
          Added <%= time_ago_in_words(@note.created_at) %> ago
        </p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to edit_project_note_path(@project, @note), class: "icon-btn", title: "Edit" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
        <% end %>
        <%= button_to project_note_path(@project, @note), method: :delete, data: { "turbo-method": :delete, turbo_confirm: 'Delete this note? Are you sure?' }, class: "icon-btn", title: "Delete" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        <% end %>
      </div>
    </div>

    <div class="p-4">
      <% if @note.content.present? %>
        <div class="prose dark:prose-invert max-w-none text-sm break-words">
          <%= format_user_content(@note.content) %>
        </div>
      <% else %>
        <p class="text-sm text-secondary">No content.</p>
      <% end %>

      <% if @note.attachment.attached? %>
        <div class="mt-3">
          <%= link_to rails_blob_path(@note.attachment, disposition: 'attachment'), class: "inline-flex items-center px-3 py-1 text-xs font-medium text-gray-700 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 dark:text-gray-300 dark:bg-gray-700 dark:border-gray-600 dark:hover:bg-gray-600", data: { turbo: false } do %>
            <svg class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
            </svg>
            <%= @note.attachment.filename %>
            (<%= number_to_human_size @note.attachment.byte_size %>)
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
