<div class="w-full">
  <% content_for :title, "Tasks" %>

  <% content_for :subnav do %>
    <div class="nav-container">
      <div class="nav-title flex items-center justify-between">
        <%= link_to tasks_path do %>
          <div class="nav-title-link">
            <span>Tasks</span>
          </div>
        <% end %>

        <%= link_to "New Task", new_task_path, class: "btn-base" %>
      </div>
    </div>
  <% end %>

  <div class="space-y-4">
    <% if current_user.personal_project %>
      <%= render 'project/tasks/form', project: current_user.personal_project %>
    <% end %>

    <div id="new-tasks-section" class="resource-container">
      <%= turbo_frame_tag "new_tasks", class: "resource-list" %>
    </div>

    <% if @assigned_tasks.any? %>
      <div class="resource-container">
        <div class="resource-header">
          <h3 class="resource-title">Assigned to you</h3>
        </div>

        <div class="resource-list">
          <% @assigned_tasks.each do |task| %>
            <%= render 'tasks/task', task: task %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @tasks_due.any? %>
      <div class="resource-container">
        <div class="resource-header">
          <h3 class="resource-title">Due soon</h3>
        </div>

        <div class="resource-list">
          <% @tasks_due.each do |task| %>
            <%= render 'tasks/task', task: task %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @tasks.any? %>
      <div class="resource-container">
        <div class="resource-list">
          <% @tasks.each do |task| %>
            <%= render 'tasks/task', task: task %>
          <% end %>
        </div>
      </div>

      <div class="flex justify-center">
        <%= paginate @tasks %>
      </div>
    <% elsif @tasks_due.none? && @assigned_tasks.none? %>
      <div class="resource-container">
        <div class="resource-empty-state">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-gray-100 dark:bg-gray-800 mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <% if params[:assigned] == 'true' %>
            <h3 class="resource-empty-title">No tasks assigned to you</h3>
            <p class="resource-empty-description">You don't have any active tasks assigned to you across your projects.</p>
          <% else %>
            <h3 class="resource-empty-title">No active tasks</h3>
            <p class="resource-empty-description">You have no active tasks across your projects. Create new tasks to get started.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
