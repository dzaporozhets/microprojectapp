<% content_for :title, "New Task" %>

<% content_for :subnav do %>
  <nav class="nav-container">
    <div class="flex flex-wrap nav-controls">
      <%= home_tabs "Tasks" %>
    </div>
  </nav>
<% end %>

<%= display_flash %>

<div class="resource-container">
  <div class="resource-header">
    <div class="flex items-center justify-between w-full">
      <div>
        <h1 class="resource-title">New task</h1>
      </div>

      <div class="flex items-center space-x-2">
        <%= link_to tasks_path, class: 'btn-sm', title: 'Back to tasks' do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <%= form_with(model: @task, url: tasks_path, data: { turbo: false }) do |form| %>
      <% if @task.errors.any? %>
        <div id="ar-errors-text" data-turbo-cache="false" class="error-box">
          <ul>
            <% @task.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-section">
        <div class="p-4">
          <div>
            <%= form.label :project_id, "Project", class: "form-label" %>
            <%= form.collection_select :project_id, @projects, :id, :name, { prompt: "Select a project" }, { class: "block w-full base-input", required: true } %>
          </div>
        </div>

        <div class="p-4">
          <div>
            <%= form.label :name, class: "form-label" %>
            <%= form.text_area :name, class: "block w-full base-input", required: true, rows: 2, placeholder: "Enter task name..." %>
          </div>
        </div>

        <div class="p-4">
          <div>
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, class: "block w-full base-input resize-y", rows: 3, placeholder: "Enter task description..." %>
          </div>
        </div>

        <div class="p-4">
          <div>
            <%= form.label :due_date, class: "form-label" %>
            <%= form.date_field :due_date, class: "block w-full base-input" %>
          </div>
        </div>

        <div class="p-4">
          <%= form.submit 'Create task', class: "btn-base" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
