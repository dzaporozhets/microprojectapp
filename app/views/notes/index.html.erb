<div class="w-full">
  <% content_for :title, "Notes" %>

  <% content_for :subnav do %>
    <nav class="nav-container">
      <div class="flex flex-wrap nav-controls">
        <%= home_tabs "Notes" %>
        <%= link_to "New Note", new_note_path, class: "btn-base" %>
      </div>
    </nav>
  <% end %>

  <% if @notes.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% @notes.each do |note| %>
        <%= link_to project_note_path(note.project, note), class: "resource-container p-4 hover:bg-neutral-50 dark:hover:bg-gray-800 block" do %>
          <h3 class="list-text-primary font-semibold truncate"><%= note.title %></h3>
          <p class="list-text-secondary mt-1"><%= note.project.name %></p>
          <% if note.content.present? %>
            <p class="mt-2 text-sm text-muted line-clamp-3 whitespace-pre-line break-all"><%= note.content.truncate(200) %></p>
          <% end %>
          <% if note.attachment.attached? %>
            <div class="mt-2 flex items-center text-xs text-muted">
              <svg class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M15.621 4.379a3 3 0 00-4.242 0l-7 7a3 3 0 004.241 4.243h.001l.497-.5a.75.75 0 011.064 1.057l-.498.501-.002.002a4.5 4.5 0 01-6.364-6.364l7-7a4.5 4.5 0 016.368 6.36l-3.455 3.553A2.625 2.625 0 119.52 9.52l3.45-3.451a.75.75 0 111.061 1.06l-3.45 3.451a1.125 1.125 0 001.587 1.595l3.454-3.553a3 3 0 000-4.242z" clip-rule="evenodd" />
              </svg>
              <%= note.attachment.filename %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="flex justify-center mt-4">
      <%= paginate @notes %>
    </div>
  <% else %>
    <div class="resource-container">
      <div class="resource-empty-state">
        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-gray-100 dark:bg-gray-800 mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <h3 class="resource-empty-title">No notes</h3>
        <p class="resource-empty-description">You have no notes across your projects. Create notes in a project to get started.</p>
      </div>
    </div>
  <% end %>
</div>
