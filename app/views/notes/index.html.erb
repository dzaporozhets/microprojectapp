<div class="w-full">
  <% content_for :title, "Notes" %>

  <% content_for :subnav do %>
    <nav class="nav-container">
      <div class="flex flex-wrap nav-controls">
        <%= home_tabs "Notes" %>
      </div>
    </nav>
  <% end %>

  <div class="space-y-4">
    <% if @notes.any? %>
      <% @notes.group_by(&:project).sort_by { |project, _| [@pinned_project_ids.include?(project.id) ? 0 : 1, project.name] }.each do |project, notes| %>
        <div class="resource-container">
          <div class="resource-header">
            <div class="flex items-center justify-between w-full">
              <div class="flex items-center">
                <h3 class="resource-title">
                  <%= link_to project.name.truncate(100), project %>
                  <% if @pinned_project_ids.include?(project.id) %>
                    <svg class="inline h-4 w-4 ml-1 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                </h3>
              </div>

              <%= link_to new_project_note_path(project), class: "btn-base-sm" do %>
                Add Note
              <% end %>
            </div>
          </div>

          <ul role="list" class="resource-list">
            <% notes.each do |note| %>
              <%= render 'project/notes/note', note: note %>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex justify-center">
        <%= paginate @notes %>
      </div>
    <% else %>
      <div class="resource-container">
        <div class="resource-empty-state">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-gray-100 dark:bg-gray-800 mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="resource-empty-title">No notes</h3>
          <p class="resource-empty-description">You have no notes across your projects. Create notes in a project to get started.</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
