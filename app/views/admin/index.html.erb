<div class=" space-y-6">
  <!-- Application Information Block -->
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h1 class="resource-title">Application Information</h1>
        <p class="resource-description">Check documentation for all supported ENV variables.</p>
      </div>
    </div>

    <div class="form-section">
      <div class="data-row">
        <dt class="data-label">Application Version</dt>
        <dd class="text-sm text-default"><%= @version %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Rails environment</dt>
        <dd class="text-sm text-default"><%= @rails_env %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">File uploads storage</dt>
        <dd class="text-sm text-default"><%= admin_config_uploads_storage %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Application domain</dt>
        <dd class="text-sm text-default">
          <% if @domain.present? %>
            <%= @domain %>
          <% else %>
            <span class="flex items-center">
              Not configured
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-orange-500 ml-1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
              </svg>
            </span>
          <% end %>
        </dd>
      </div>
      <div class="data-row">
        <dt class="data-label">New users sign-up</dt>
        <dd class="text-sm text-default"><%= @app_signup %></dd>
      </div>
      <div class="p-4">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <dt class="data-label mb-1">
              Restrict sign-up to a single domain
            </dt>
            <dd class="text-sm text-gray-600 dark:text-gray-400">
              For instance, only users whose email addresses end with @yourcompany.com can register.
            </dd>
          </div>
          <dd class="text-sm text-default ml-4 text-right"><%= @allowed_domain %></dd>
        </div>
      </div>
      <div class="data-row">
        <dt class="data-label">OAuth Login Providers</dt>
        <dd class="text-sm text-default">
          <%= @oauth_providers.present? ? @oauth_providers : "Not configured" %>
        </dd>
      </div>
      <div class="p-4">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <dt class="data-label mb-1">Email Login</dt>
            <dd class="text-sm text-gray-600 dark:text-gray-400">
              Controls whether users can register and log in using email and password. This setting does not affect OAuth providers like Google or Microsoft.
            </dd>
          </div>
          <dd class="text-sm text-default ml-4 text-right">
            <%= @disable_email_login ? "Disabled (OAuth only)" : "Enabled" %>
          </dd>
        </div>
      </div>
    </div>
  </div>

  <!-- Database Information Block -->
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h1 class="resource-title">Database Information</h1>
        <p class="resource-description"><%= ActiveRecord::Base.connection.current_database %></p>
      </div>
    </div>

    <div class="form-section">
      <div class="data-row">
        <dt class="data-label">Users</dt>
        <dd class="text-sm text-default"><%= @total_users %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Projects</dt>
        <dd class="text-sm text-default"><%= @total_projects %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Tasks</dt>
        <dd class="text-sm text-default"><%= @total_tasks %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Comments</dt>
        <dd class="text-sm text-default"><%= @total_comments %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">
          Activities <span class="font-light text-gray-500">(24 hours)</span>
        </dt>
        <dd class="text-sm text-default"><%= @recent_activities_count %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">
          Users <span class="font-light text-gray-500">(24 hours)</span>
        </dt>
        <dd class="text-sm text-default"><%= @recent_users_count %></dd>
      </div>
    </div>
  </div>
</div>
