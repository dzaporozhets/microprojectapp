<div class=" space-y-6">
  <!-- User Header -->
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h1 class="resource-title"><%= @user.email %></h1>
        <p class="resource-description">User account details and statistics.</p>
      </div>
    </div>
  </div>

  <!-- Account Information -->
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h2 class="resource-title">Account Information</h2>
        <p class="resource-description">Basic account details and settings.</p>
      </div>
    </div>

    <div class="form-section">
      <div class="data-row">
        <dt class="data-label">ID</dt>
        <dd class="text-sm text-default"><%= @user.id %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Email</dt>
        <dd class="text-sm text-default"><%= @user.email %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Created At</dt>
        <dd class="text-sm text-default"><%= @user.created_at %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Updated At</dt>
        <dd class="text-sm text-default"><%= @user.updated_at %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Admin</dt>
        <dd class="text-sm text-default"><%= @user.admin %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Allow Invites</dt>
        <dd class="text-sm text-default"><%= @user.allow_invites %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Provider</dt>
        <dd class="text-sm text-default"><%= @user.provider %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Created from OAuth</dt>
        <dd class="text-sm text-default"><%= @user.created_from_oauth %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">OAuth Linked At</dt>
        <dd class="text-sm text-default"><%= @user.oauth_linked_at %></dd>
      </div>
    </div>
  </div>

  <!-- User Statistics -->
  <div class="resource-container">
    <div class="resource-header">
      <div>
        <h2 class="resource-title">User Statistics</h2>
        <p class="resource-description">Database records and activity metrics.</p>
      </div>
    </div>

    <div class="form-section">
      <div class="data-row">
        <dt class="data-label">Projects created</dt>
        <dd class="text-sm text-default"><%= @user.projects.count %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Tasks created</dt>
        <dd class="text-sm text-default"><%= @user.tasks.count %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Comments created</dt>
        <dd class="text-sm text-default"><%= @user.comments.count %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Failed Attempts</dt>
        <dd class="text-sm text-default"><%= @user.failed_attempts %></dd>
      </div>
      <div class="data-row">
        <dt class="data-label">Locked At</dt>
        <dd class="text-sm text-default"><%= @user.locked_at %></dd>
      </div>
    </div>
  </div>

  <!-- Delete Account -->
  <% unless current_user == @user %>
    <div class="resource-container border-red-500 border-2">
      <div class="resource-header">
        <div>
          <h2 class="resource-title text-red-600 dark:text-red-400">Delete Account</h2>
          <p class="resource-description">This will completely remove the account. All data will be lost.</p>
        </div>
      </div>

      <div class="p-4">
        <%= button_to 'Delete this account', admin_user_path(@user), method: :delete, data: { turbo_confirm: "Delete account with all the data? Are you sure?", confirm: "Are you sure you want to delete this user?" }, class: 'btn-remove' %>
      </div>
    </div>
  <% end %>
</div>
