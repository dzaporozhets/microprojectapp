#!/usr/bin/env bash
set -e

echo "=== RSpec ==="
bundle exec rspec

echo ""
echo "=== Coverage Check ==="
min_coverage=98
coverage=$(ruby -e 'require "json"; data = JSON.parse(File.read("coverage/.last_run.json")); puts data["result"]["line"]')
passed=$(ruby -e "puts $coverage >= $min_coverage ? 'yes' : 'no'")
if [ "$passed" != "yes" ]; then
  echo "FAIL: Coverage is ${coverage}%, minimum required is ${min_coverage}%"
  exit 1
else
  echo "OK: ${coverage}% line coverage (>= ${min_coverage}%)"
fi

echo ""
echo "=== RuboCop ==="
bin/rubocop

echo ""
echo "=== Brakeman ==="
bundle exec brakeman -q

echo ""
echo "All checks passed!"
